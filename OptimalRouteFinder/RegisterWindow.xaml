<Window x:Class="OptimalRouteFinder.RegisterWindow"  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:OptimalRouteFinder.ViewModels"
        Title="Register"
        Height="540"
        Width="350"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#F3F6FB">

    <Border CornerRadius="12"
            Padding="25"
            Width="300"
            Background="White"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

        <StackPanel>

            <TextBlock Text="Գրանցում"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="#2C3E50"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>
            <TextBlock Text="Լրացրեք տվյալները գրանցվելու համար"
                       FontSize="13"
                       Foreground="#7F8C8D"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <TextBlock Text="Օգտանուն" Foreground="#34495E"/>
            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                     Height="38" FontSize="14" Padding="10"
                     Background="#ECF0F1" BorderThickness="0"
                     Margin="0,0,0,15"/>

            <TextBlock Text="Էլեկտրոնային փոստ" Foreground="#34495E"/>
            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                     Height="38" FontSize="14" Padding="10"
                     Background="#ECF0F1" BorderThickness="0"
                     Margin="0,0,0,15"/>

            <TextBlock Text="Գաղտնաբառը" Foreground="#34495E"/>
            <PasswordBox Height="38" FontSize="14" Padding="10"
                         Background="#ECF0F1" BorderThickness="0"
                         Margin="0,0,0,15"
                         helpers:PasswordBoxHelper.BindPassword="True"
                         helpers:PasswordBoxHelper.BoundPassword="{Binding Password, Mode=TwoWay}"/>

            <TextBlock Text="Հաստատել գաղտնաբառը" Foreground="#34495E"/>
            <PasswordBox Height="38" FontSize="14" Padding="10"
                         Background="#ECF0F1" BorderThickness="0"
                         Margin="0,0,0,25"
                         helpers:PasswordBoxHelper.BindPassword="True"
                         helpers:PasswordBoxHelper.BoundPassword="{Binding ConfirmPassword, Mode=TwoWay}"/>

            <Button Content="Գրանցվել"
                    Height="42"
                    FontSize="15"
                    FontWeight="SemiBold"
                    Background="#4A90E2"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Command="{Binding RegisterCommand}"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                <Button Content="Վերադառնալ մուտքի էջին"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#4A90E2"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Command="{Binding GoToLoginCommand}"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>