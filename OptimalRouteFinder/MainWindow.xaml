<Window x:Class="OptimalRouteFinder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:OptimalRouteFinder.ViewModels"
        Title="Օպտիմալ երթուղիների հաշվարկման համակարգ" Height="900" Width="1200"
        Background="#FF4A90E2"
        FontFamily="Segoe UI" FontSize="14">

    <Window.Resources>
        <!-- Rounded Button Style -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#4CAF50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,6"/>
            <!-- more padding -->
            <Setter Property="Margin" Value="4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                        CornerRadius="6"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Margin="6,2"/>
                            <!-- extra space between text and border -->
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#45a049"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#a5d6a7"/>
                                <Setter Property="Foreground" Value="#555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Rounded TextBox Style -->
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="4"/>
            <Setter Property="BorderBrush" Value="#ccc"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <ScrollViewer Margin="0" x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section Header Style -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Margin" Value="0,6,0,4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340"/>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL -->
        <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="12" Margin="0,0,4,0" >
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock 
               FontSize="18" 
               FontWeight="Bold" 
               Foreground="Black" 
                        TextAlignment="Center"
               Margin="0,0,0,12" Height="51">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="1" Opacity="0.4"/>
                        </TextBlock.Effect><Run Text="Օպտիմալ երթուղիների"/><LineBreak/><Run Text=" հաշվարկման համակարգ"/></TextBlock>

                    <!-- Template Selection -->
                    <TextBlock Text="Քարտեզի շաբլոն" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,6">
                        <Border CornerRadius="4" BorderBrush="#1E3A8A" BorderThickness="1" Background="White">
                            <ComboBox Width="200"
                       ItemsSource="{Binding TemplateNames}" 
                       SelectedItem="{Binding SelectedTemplate}" 
                      IsEditable="True"
                      IsTextSearchEnabled="True"
                      Padding="2"/>
                        </Border>
                        <Button Content="Բեռնել" Command="{Binding LoadTemplateCommand}" Margin="5,0,0,0" Background="#FF4A90E2" Foreground="White"/>
                    </StackPanel>

                    <!-- Save Template -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBox Width="140" Text="{Binding NewTemplateName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0"/>
                        <Button Content="Պահպանել" Command="{Binding SaveTemplateCommand}" Background="#FF4A90E2" Foreground="White" />
                        <Button Content="Ջնջել" Command="{Binding DeleteTemplateCommand}"  Background="#FFA5A5A5" Foreground="White"/>
                    </StackPanel>

                    <!-- Add City -->
                    <TextBlock Text="Քաղաքի անունը" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,6">
                        <Border CornerRadius="4" BorderBrush="#1E3A8A" BorderThickness="1" Background="White">
                            <TextBox Width="140" Text="{Binding NewCityName, UpdateSourceTrigger=PropertyChanged}"/>
                        </Border>
                        <Button Content="Ավելացնել քաղաք" Command="{Binding AddCityCommand}" HorizontalAlignment="Right" Margin="5,1,1,1" Background="#FF4A90E2" Foreground="White"/>
                    </StackPanel>

                    <!-- Cities List -->
                    <TextBlock Text="Քաղաքներ" Style="{StaticResource SectionHeader}" FontSize="13"/>
                    <ListBox ItemsSource="{Binding Cities}" Height="120" SelectedItem="{Binding SelectedCity}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Width="200" FontSize="12"/>
                                    <Button Content="X" HorizontalAlignment="Right"
                        Command="{Binding DataContext.DeleteCityCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="{Binding}" 
                        Height="24" Margin="40,0,0,0" Background="#FFA5A5A5" Foreground="White"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Separator Margin="0,8,0,8"/>

                    <!-- Add Road -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <!-- From City -->
                        <Border CornerRadius="4" BorderBrush="#1E3A8A" BorderThickness="1" Background="White">
                            <ComboBox Width="140" 
                  ItemsSource="{Binding RoadFromOptions}" 
                  DisplayMemberPath="Name" 
                  SelectedItem="{Binding RoadFrom, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                  Padding="2"/>
                        </Border>

                        <!-- To City -->
                        <Border CornerRadius="4" BorderBrush="#1E3A8A" BorderThickness="1" Background="White" Margin="6,0,0,0">
                            <ComboBox Width="140" 
                  ItemsSource="{Binding RoadToOptions}" 
                  DisplayMemberPath="Name" 
                  SelectedItem="{Binding RoadTo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                  Padding="2"/>
                        </Border>
                    </StackPanel>

                    <!-- Distance and Button -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <TextBlock Text="Հեռավորություն" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="13"/>

                        <Border CornerRadius="4" BorderBrush="#1E3A8A" BorderThickness="1" Background="White">
                            <TextBox Width="40" Text="{Binding RoadDistance, UpdateSourceTrigger=PropertyChanged}" Padding="2"/>
                        </Border>
                        <Button Content="Ավելացնել ճանապարհ" Command="{Binding AddRoadCommand}" HorizontalAlignment="Right" Margin="5,1,1,1" Background="#FF4A90E2" FontSize="11" Foreground="White"/>
                    </StackPanel>

                    <Separator Margin="0,8,0,8"/>
                    <!-- Roads List -->
                    <TextBlock Text="Ճանապարհներ" Style="{StaticResource SectionHeader}" FontSize="13"/>
                    <ListBox ItemsSource="{Binding Roads}" Height="120">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Display}" VerticalAlignment="Center"  Width="200" FontSize="12"/>
                                    <Button Content="X" Command="{Binding DeleteRoadCommand}" HorizontalAlignment="Right" Margin="40,0,0,0" Background="#FFA5A5A5" Foreground="White"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <!-- Route Options -->
                    <Border Background="#FF4A90E2" CornerRadius="8" BorderBrush="#2E8B57" BorderThickness="1" Padding="12" Margin="0,4,0,8">
                        <StackPanel>
                            <TextBlock Text="Երթուղու կարգավորումներ" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,8"/>

                            <!-- Start City -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4" VerticalAlignment="Center">
                                <TextBlock Text="Սկզբնակետ" Width="90" VerticalAlignment="Center" Foreground="White"/>
                                <Border CornerRadius="4" BorderBrush="#2E8B57" BorderThickness="1" Background="White">
                                    <ComboBox Width="180" 
                          ItemsSource="{Binding Cities}" 
                          DisplayMemberPath="Name" 
                          SelectedItem="{Binding StartCity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                          Padding="2"/>
                                </Border>
                            </StackPanel>

                            <!-- End City -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4" VerticalAlignment="Center">
                                <TextBlock Text="Վերջնակետ" Width="90" VerticalAlignment="Center" Foreground="White"/>
                                <Border CornerRadius="4" BorderBrush="#FF4A90E2" BorderThickness="1" Background="White">
                                    <ComboBox Width="180" 
                          ItemsSource="{Binding Cities}" 
                          DisplayMemberPath="Name" 
                          SelectedItem="{Binding EndCity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                          Padding="2"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Must-visit cities -->
                    <TextBlock Text="Պարտադիր այցելվող քաղաքներ" Style="{StaticResource SectionHeader}" FontSize="13"/>
                    <ListBox ItemsSource="{Binding MustVisitOptions}" Height="120">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsChecked, UpdateSourceTrigger=PropertyChanged}" />

                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Button Content="Հաշվարկել օպտիմալ երթուղին" Margin="0,8,0,0" Command="{Binding ComputeRouteCommand}" Height="36" Background="#FF4A90E2" Foreground="White"/>
                    <Button Content="Մաքրել" Margin="0,8,0,0"  Command="{Binding ClearAllCommand}" Height="36"  Background="#FFA5A5A5" Foreground="White" Padding="8,4"/>
                    <!-- Logs -->
                    <ScrollViewer MaxHeight="100" VerticalScrollBarVisibility="Auto" Margin="0,6,0,0">
                        <ItemsControl ItemsSource="{Binding LogLines}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Result -->
                    <TextBlock Text="{Binding ResultText}" FontWeight="Bold" Margin="0,6,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Divider -->
        <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch"/>
        <Button Content="Ելք"
        Width="40"
        Height="24"
        HorizontalAlignment="Right"
        VerticalAlignment="Top"
        Command="{Binding LogoutCommand}"
        Background="Gray"
        Foreground="White"
        FontWeight="SemiBold"
        BorderThickness="0"
        Cursor="Hand" Margin="7,4"/>
        <!-- MAP CANVAS -->
        <Border Grid.Column="2" Background="White"  CornerRadius="8">
            <Canvas x:Name="MapCanvas" DataContext="{Binding}" Loaded="MapCanvas_Loaded"/>
        </Border>

    </Grid>
</Window>
